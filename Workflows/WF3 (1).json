      "id": "005538e5-a64c-467a-962d-41288f331750",
      "name": "Every 5 Minutes Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -208,
        240
      ],
      "notes": "Replaces the Google Sheets Trigger node, which has a known-unreliable OAuth2 credential dropdown in several n8n versions. Same Schedule Trigger node type already working flawlessly in WF1 (daily 8pm) and WF2 (Sunday 7am) -- just on a 5-minute interval here since this workflow needs to behave close to real-time."
    },
    {
      "parameters": {
        "documentId": {
          "__rl": true,
          "value": "16DwHErEgpzU2A2MUlbxCNuLNqEd1TSPGwjdaB01jmg0",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Trip_Data",
          "mode": "name"
        },
        "options": {}
      },
      "id": "29876586-9ef3-4582-a57d-a93180b1fac7",
      "name": "Read Trip_Data",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        48,
        240
      ],
      "alwaysOutputData": true,
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "4lEUW6YRutStEjQc",
          "name": "Google Sheets account"
        }
      },
      "notes": "Plain Google Sheets read node -- the type whose credential dropdown has auto-populated correctly for you every time in WF1 and WF2. Reads the whole sheet each run; the next node filters out anything already alerted."
    },
    {
      "parameters": {
        "jsCode": "// Uses n8n's built-in workflow static data as a lightweight memory of which\n// Trip_IDs have already been alerted on -- persists automatically between\n// scheduled runs, no extra sheet or setup required.\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.alertedTripIds) staticData.alertedTripIds = [];\n\nconst allRows = $input.all().map(i => i.json);\n\nconst highVarianceRows = allRows.filter(r =>\n  r.Flag_Colour === 'RED' ||\n  r.High_Variance_Unmatched_Alert === true ||\n  r.High_Variance_Unmatched_Alert === 'TRUE'\n);\n\nconst newRows = highVarianceRows.filter(r => !staticData.alertedTripIds.includes(r.Trip_ID));\n\n// Remember these so the next 5-minute poll doesn't re-alert on them.\nfor (const r of newRows) {\n  staticData.alertedTripIds.push(r.Trip_ID);\n}\n\n// Cap memory so it doesn't grow forever across months of runs.\nif (staticData.alertedTripIds.length > 500) {\n  staticData.alertedTripIds = staticData.alertedTripIds.slice(-500);\n}\n\nreturn newRows.map(r => ({ json: r }));"
      },
      "id": "cdbe097d-6b71-45e9-943a-70d64d8194a5",
      "name": "Detect New High-Variance Trips",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        304,
        240
      ],
      "notes": "This one node replaces both the old Google Sheets Trigger AND the old High Variance Filter IF node. It does two jobs: (1) the same RED/High_Variance_Unmatched_Alert check as before, (2) dedup against alerts already sent, using Trip_ID as the unique key (e.g. 'TRK-001_2026-07-02'). If nothing new, it returns 0 items and everything downstream simply does nothing that run -- no error, no empty-sheet crash risk since this is a Code node, not a Sheets read."
    },
    {
      "parameters": {
        "jsCode": "const r = $json;\n\nconst pct = (r.Variance_Percent !== null && r.Variance_Percent !== undefined && r.Variance_Percent !== '')\n  ? Number(r.Variance_Percent).toFixed(2)\n  : 'N/A';\nconst pkr = (r.Variance_PKR !== null && r.Variance_PKR !== undefined && r.Variance_PKR !== '')\n  ? Number(r.Variance_PKR).toLocaleString()\n  : 'N/A';\n\nconst reason = (r.Flag_Colour === 'RED')\n  ? `RED flag - ${pct}% variance, above the Red_Threshold_Pct in Config`\n  : 'High-variance unmatched trip - no Form_Responses match found, but the underlying GPS/claim gap still exceeds threshold';\n\nconst text = `:rotating_light: *Real-Time Fuel Variance Alert*\\n*Truck:* ${r.Truck_ID || 'UNKNOWN'} (${r.Registration || 'N/A'})\\n*Driver:* ${r.Driver_ID || 'UNKNOWN'}\\n*Trip:* ${r.Trip_ID || 'N/A'} on ${r.Trip_Date || 'N/A'}\\n*Variance:* PKR ${pkr} (${pct}%)\\n*Reason:* ${reason}\\n*Status:* ${r.Reconciliation_Status || 'N/A'}`;\n\nreturn [{ json: {\n  text,\n  Truck_ID: r.Truck_ID || '',\n  Registration: r.Registration || '',\n  Driver_ID: r.Driver_ID || '',\n  Trip_ID: r.Trip_ID || ''\n} }];"
      },
      "id": "f1ab8d40-af0f-484f-8658-93ebd7f9993b",
      "name": "Format Real-Time Alert Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        240
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://slack.com/api/chat.postMessage",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "slackApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ channel: \"new-channel\", text: $json.text }) }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": true
            }
          }
        }
      },
      "id": "1c9048a2-8381-4584-9f9a-6684cd676d5b",
      "name": "Post Real-Time Alert to Slack",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
