          "id": "UiRBACFZpfjndzoe",
          "name": "Slack account"
        }
      },
      "notes": "Same slackApi credential confirmed working in WF2. Method explicitly POST. Channel hardcoded to 'new-channel'."
    },
    {
      "parameters": {
